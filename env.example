# Service bootstrap
# Default env file location: $APP_DATA_DIR/config/.env
APP_PORT=8000
APP_DATA_DIR=
APP_CONFIG_DIR=
APP_ENV_FILE=
APP_INSTANCE_NAME=
APP_BASE_URL=

# Notification webhooks
WEBHOOK_LOGGING_ENABLED=false
WEBHOOK_LOGGING_ENDPOINT=
WEBHOOK_LOGGING_BEARER_TOKEN=
WEBHOOK_LOGGING_TIMEOUT_SECONDS=10
WEBHOOK_LOGGING_RETRY_COUNT=2
WEBHOOK_LOGGING_MIN_SEVERITY=warning
DISCORD_NOTIFICATION_WEBHOOK_ENABLED=false
DISCORD_NOTIFICATION_WEBHOOK_URL=
DISCORD_NOTIFICATION_WEBHOOK_USERNAME=LynxPoster
DISCORD_NOTIFICATION_MIN_SEVERITY=warning

# Scheduler
SCHEDULER_AUTORUN_INTERVAL_SECONDS=300

# Authentication
AUTH_OIDC_ENABLED=false
AUTH_OIDC_ISSUER_URL=
AUTH_OIDC_CLIENT_ID=
AUTH_OIDC_CLIENT_SECRET=
AUTH_OIDC_SCOPE=openid profile email
AUTH_OIDC_GROUPS_CLAIM=groups
AUTH_OIDC_USERNAME_CLAIM=preferred_username
AUTH_OIDC_ADMIN_GROUPS=
AUTH_OIDC_USER_GROUPS=
AUTH_SESSION_SECRET=

# Instagram webhooks / giveaways
INSTAGRAM_WEBHOOKS_ENABLED=false
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=
INSTAGRAM_APP_SECRET=

# Deprecated compatibility aliases for one release
ERROR_ALERTS_ENABLED=
ERROR_ALERTS_ENDPOINT=
ERROR_ALERTS_BEARER_TOKEN=
ERROR_ALERTS_TIMEOUT_SECONDS=
ERROR_ALERTS_RETRY_COUNT=

# Legacy persona import and default account seeding
BSKY_HANDLE=
BSKY_PASSWORD=
BSKY_SESSION_STRING=
MASTODON_HANDLE=
MASTODON_INSTANCE=
MASTODON_TOKEN=
TWITTER_APP_KEY=
TWITTER_APP_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_USERNAME=
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
TUMBLR_CONSUMER_KEY=
TUMBLR_CONSUMER_SECRET=
TUMBLR_OAUTH_TOKEN=
TUMBLR_OAUTH_SECRET=
TUMBLR_BLOG_NAME=
INSTAGRAM_API_KEY=
INSTAGRAPI_USERNAME=
INSTAGRAPI_PASSWORD=
INSTAGRAPI_SESSIONID=
# Legacy Graph publish ID; not required for instagrapi destination publishing.
INSTAGRAM_USER_ID=

TWITTER_CROSSPOSTING=false
MASTODON_CROSSPOSTING=true
DISCORD_CROSSPOSTING=true
TELEGRAM_CROSSPOSTING=false
TUMBLR_CROSSPOSTING=true
INSTAGRAM_CROSSPOSTING=false
MASTODON_VISIBILITY=public
MENTIONS=strip
POST_DEFAULT=true
MASTODON_LANG=
TWITTER_LANG=
QUOTE_POSTS=true
MAX_RETRIES=5
POST_TIME_LIMIT=12
MAX_PER_HOUR=0
OVERFLOW_POST=retry
